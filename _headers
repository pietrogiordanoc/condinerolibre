# Headers de Seguridad y SEO para Netlify
# ConDineroLibre - Configuración Optimizada

/*
  # Seguridad
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()

  # Cache Control para HTML
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  # Sin cache para HTML (siempre buscar actualizaciones)
  Cache-Control: public, max-age=0, must-revalidate

/*.css
  # Cache de 1 año para CSS
  Cache-Control: public, max-age=31536000, immutable

/*.js
  # Cache de 1 año para JavaScript
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  # Cache de 1 año para imágenes
  Cache-Control: public, max-age=31536000, immutable

/*.jpeg
  # Cache de 1 año para imágenes
  Cache-Control: public, max-age=31536000, immutable

/*.png
  # Cache de 1 año para imágenes
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  # Cache de 1 año para imágenes WebP
  Cache-Control: public, max-age=31536000, immutable

/*.avif
  # Cache de 1 año para imágenes AVIF
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  # Cache de 1 año para SVG
  Cache-Control: public, max-age=31536000, immutable

/*.woff
  # Cache de 1 año para fuentes
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  # Cache de 1 año para fuentes
  Cache-Control: public, max-age=31536000, immutable

/*.ttf
  # Cache de 1 año para fuentes
  Cache-Control: public, max-age=31536000, immutable

/sitemap.xml
  # Cache de 1 día para sitemap
  Cache-Control: public, max-age=86400

/robots.txt
  # Cache de 1 día para robots.txt
  Cache-Control: public, max-age=86400
